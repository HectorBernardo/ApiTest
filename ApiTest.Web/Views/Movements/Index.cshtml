@using ApiTest.Web.Models
@model IEnumerable<MovementViewModel>

@{
    ViewData["Title"] = "Movimientos de Inventario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Lista de movimientos</h2>
        <a href="/Movements/Create" class="btn btn-success">Actualizar stock</a>
    </div>
    <hr />

    <div class="card shadow-sm p-3">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Producto</th>
                    <th>Cantidad</th>
                    <th>Tipo</th>
                    <th>Descripcion</th>
                    <th>Fecha</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MovementId</td>
                            <td>@item.ProductName</td>
                            <td>@item.Quantity</td>
                            <td>
                                @if (item.MovementType == "Output")
                                {
                                    <span class="badge bg-danger">Salida</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Entrada</span>
                                }
                            </td>
                            <td>@item.Reason</td>
                            <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No se encontraron movimientos registrados en el sistema.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>