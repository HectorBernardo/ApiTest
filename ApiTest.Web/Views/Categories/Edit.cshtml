@using ApiTest.Web.Models
@model CategoryViewModel

@{
    ViewData["Title"] = "Editar Categoría";
}

<div class="container mt-4 col-md-6">
    <h2>Editar Categoría</h2>
    <hr />

    <p>Depuración rápida: @Model.Name - @Model.Description</p>

    <div class="card shadow-sm p-4">
        <form action="/Categories/Edit/@Model.CategoryId" method="post">
            <input type="hidden" name="CategoryId" value="@Model.CategoryId" />

            <div class="mb-3">
                <label class="form-label">Nombre</label>
                <input type="text" name="Name" value="@Model.Name" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Descripción</label>
                <textarea name="Description" class="form-control" rows="3">@Model.Description</textarea>
            </div>

            <div class="d-flex justify-content-between">
                <a href="/Categories/Index" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-primary">Actualizar</button>
            </div>
        </form>
    </div>
</div>