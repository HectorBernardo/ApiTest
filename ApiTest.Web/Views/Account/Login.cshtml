@{
    ViewData["Title"] = "Acceso";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <!-- Agrega Bootstrap CSS aquí -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
</head>
<body>

    <form action="~/Account/Authenticate" method="post">
        <div class="container mt-5 text-center">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="card shadow p-4">
                        <h2>Prueba Técnica - Fase 3</h2>
                        <p class="text-muted mt-2">Haz clic en el botón para iniciar sesión de forma automática y acceder al sistema.</p>
                        <button type="submit" class="btn btn-success mt-3">Entrar al Sistema</button>
                    </div>
                </div>
            </div>
        </div>
    </form>

</body>
</html>